menu "ZMK USB Bridge"

menu "BLE Pairing Filter"

config ZMK_USB_BRIDGE_PAIRING_NAME_ALLOWLIST_ENABLED
    bool "Enable pairing name allowlist"
    default n
    help
        Adds a local-name allowlist check to unbonded pairing candidate filtering.
        This is a supplementary safeguard only for initial pairing and is not used
        as the identity source after bonding.

config ZMK_USB_BRIDGE_PAIRING_NAME_ALLOWLIST
    string "Pairing name allowlist"
    depends on ZMK_USB_BRIDGE_PAIRING_NAME_ALLOWLIST_ENABLED
    default ""
    help
        Comma-separated list of accepted BLE local names during initial pairing.
        Example: LalapadGen2,MyOtherBoard

endmenu

endmenu
